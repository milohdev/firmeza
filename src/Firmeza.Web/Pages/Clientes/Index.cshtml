@page
@model Firmeza.Web.Pages.Clientes.IndexModel

@{
    ViewData["Title"] = "Clientes";
}

<h1>Clientes</h1>

<div class="d-flex justify-content-between align-items-center mb-2">
    <a asp-page="Create" class="btn btn-primary">Crear Nuevo</a>
    <div class="dropdown">
        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
            ⬇ Exportar
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
            <li>
                <form method="get" class="d-contents">
                    <input type="hidden" name="Busqueda" value="@Model.Busqueda" />
                    <button type="submit" name="export" value="excel" class="dropdown-item">
                        📊 Excel
                    </button>
                </form>
            </li>
            <li>
                <form method="get" class="d-contents">
                    <input type="hidden" name="Busqueda" value="@Model.Busqueda" />
                    <button type="submit" name="export" value="pdf" class="dropdown-item">
                        📄 PDF
                    </button>
                </form>
            </li>
        </ul>
    </div>
</div>

<form method="get" class="row g-3 mb-3">
    <div class="col-auto">
        <input type="text" name="Busqueda" value="@Model.Busqueda" class="form-control" placeholder="Buscar por nombre o documento..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-secondary">Buscar</button>
        <a asp-page="./Index" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

<table class="table">
    <thead>
    <tr>
        <th>@Html.DisplayNameFor(model => model.Client[0].Nombre)</th>
        <th>@Html.DisplayNameFor(model => model.Client[0].Documento)</th>
        <th>@Html.DisplayNameFor(model => model.Client[0].Email)</th>
        <th>@Html.DisplayNameFor(model => model.Client[0].Telefono)</th>
        <th>@Html.DisplayNameFor(model => model.Client[0].Direccion)</th>
        <th>@Html.DisplayNameFor(model => model.Client[0].Edad)</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Client) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
            <td>@Html.DisplayFor(modelItem => item.Documento)</td>
            <td>@Html.DisplayFor(modelItem => item.Email)</td>
            <td>@Html.DisplayFor(modelItem => item.Telefono)</td>
            <td>@Html.DisplayFor(modelItem => item.Direccion)</td>
            <td>@Html.DisplayFor(modelItem => item.Edad)</td>
            <td class="text-nowrap">
                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Editar</a>
                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Detalles</a>
                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Eliminar</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (!Model.Client.Any())
{
    <p class="text-muted">No se encontraron clientes.</p>
}