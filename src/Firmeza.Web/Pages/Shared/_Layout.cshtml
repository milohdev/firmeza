<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Firmeza</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Firmeza.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" id="wrapper">

        <!-- Sidebar -->
        <div id="sidebar" class="text-white">
            <div class="sidebar-top p-3">
                <h4 class="text-center mb-4">FIRMEZA</h4>

                <div class="sidebar-group-label">Principal</div>
                <ul class="nav nav-pills flex-column mb-2">
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")"
                           asp-area="" asp-page="/Index">
                            🏠 Inicio
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Productos") == true ? "active" : "")"
                           asp-area="" asp-page="/Productos/Index">
                            📦 Productos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Clientes") == true ? "active" : "")"
                           asp-area="" asp-page="/Clientes/Index">
                            👥 Clientes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Ventas") == true ? "active" : "")"
                           asp-area="" asp-page="/Ventas/Index">
                            🧾 Ventas
                        </a>
                    </li>
                </ul>

                <div class="sidebar-divider"></div>

                <div class="sidebar-group-label">Herramientas</div>
                <ul class="nav nav-pills flex-column">
                    <li class="nav-item">
                        <a class="nav-link text-white @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/CargaMasiva") == true ? "active" : "")"
                           asp-area="" asp-page="/CargaMasiva/Index">
                            📥 Carga Masiva
                        </a>
                    </li>
                </ul>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="sidebar-user p-3">
                    <div class="sidebar-user-avatar">
                        @(User.Identity.Name?.Substring(0, 1).ToUpperInvariant() ?? "U")
                    </div>
                    <div class="sidebar-user-info">
                        <div class="sidebar-user-email">@User.Identity.Name</div>
                        <div class="sidebar-user-role">Administrador</div>
                    </div>
                </div>
            }
        </div>

        <!-- Contenido principal -->
        <div class="flex-grow-1 d-flex flex-column">
            <nav class="navbar navbar-expand-sm navbar-light bg-white mb-3">
                <div class="container-fluid">
                    <span class="navbar-brand">@ViewData["Title"]</span>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </nav>

            <div class="container-fluid flex-grow-1">
                <main role="main" class="pb-3">
                    @if (TempData["Exito"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                            @TempData["Exito"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </main>
            </div>

            <footer class="border-top text-center">
                <div class="container-fluid">
                    &copy; 2026 Firmeza · Materiales de construcción
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
