@page
@model IndexModel
@using Firmeza.Web.Models
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">Dashboard</h1>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Productos</h5>
                <p class="card-text fs-2">@Model.TotalProductos</p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Clientes</h5>
                <p class="card-text fs-2">@Model.TotalClientes</p>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Ventas</h5>
                <p class="card-text fs-2">@Model.TotalVentas</p>
            </div>
        </div>
    </div>
</div>

<h5 class="mt-4 mb-3">Actividad reciente</h5>

@if (!Model.UltimasVentas.Any())
{
    <p class="text-muted">Sin ventas registradas aún.</p>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Total</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.UltimasVentas)
                    {
                        <tr>
                            <td>@v.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@v.Cliente?.Nombre</td>
                            <td>@v.Total.ToString("C")</td>
                            <td>
                                @{
                                    var badge = v.Estado switch
                                    {
                                        SaleStatus.Pagada  => "bg-success",
                                        SaleStatus.Anulada => "bg-danger",
                                        _                  => "bg-warning text-dark"
                                    };
                                }
                                <span class="badge @badge">@v.Estado</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
