@page
@model Firmeza.Web.Pages.Ventas.DeleteModel
@using Firmeza.Web.Models

@{
    ViewData["Title"] = "Eliminar Venta";
}

<h1>Eliminar Venta</h1>

<h3>¿Está seguro de que desea eliminar esta venta?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Fecha</dt>
        <dd class="col-sm-10">@Model.Venta.Fecha.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-2">Cliente</dt>
        <dd class="col-sm-10">@Model.Venta.Cliente?.Nombre</dd>

        <dt class="col-sm-2">Total</dt>
        <dd class="col-sm-10">@Model.Venta.Total.ToString("C")</dd>

        <dt class="col-sm-2">Estado</dt>
        <dd class="col-sm-10">@Model.Venta.Estado</dd>

        <dt class="col-sm-2">Productos</dt>
        <dd class="col-sm-10">@Model.Venta.Detalles.Count línea(s)</dd>
    </dl>

    <div class="alert alert-warning">
        Al eliminar esta venta, el stock de los productos será restaurado.
    </div>

    <form method="post">
        <input type="hidden" asp-for="Venta.Id" />
        <input type="submit" value="Eliminar" class="btn btn-danger" />
        <a asp-page="./Index" class="btn btn-outline-secondary ms-2">Cancelar</a>
    </form>
</div>